{
  "name": "minikodi",
  "version": "1.0.0",
  "description": "Reproductor multimedia estilo Kodi con instalación automática de mods y soporte torrent",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --linux",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "test": "jest"
  },
  "keywords": ["kodi", "media", "player", "torrent", "mods"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "extract-zip": "^2.0.1"
  },
  "build": {
    "appId": "com.minikodi.player",
    "productName": "MiniKodi",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "resources/**/*"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "resources/icon.ico"
    },
    "linux": {
      "target": ["deb", "AppImage"],
      "icon": "resources/icon.png",
      "category": "AudioVideo"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    }
  }
}
